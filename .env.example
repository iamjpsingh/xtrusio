# Copy this file to `.env` and fill in the values from your managed Supabase project.
# `.env` is gitignored — never commit it.

# === Process role (required) ===
# Set to "api" for the FastAPI/Uvicorn process, "worker" for Dramatiq/Prefect.
# Local dev: `make api` and `make worker` set this automatically.
XTRUSIO_PROCESS_ROLE=api

# === Database (managed Supabase Postgres) ===
# Get from Supabase Dashboard → Project Settings → Database → Connection string.
# Use the DIRECT connection (port 5432, host `db.<project-ref>.supabase.co`)
# for Alembic migrations and the FastAPI server. The transaction pooler (6543)
# does NOT support PREPARE and breaks asyncpg + Alembic.
# If you must run on the pooler, switch to the SESSION pooler (port 5432,
# host `aws-0-<region>.pooler.supabase.com`) — transaction pooler is unsupported.
DATABASE_URL=postgresql+asyncpg://postgres:<DB_PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres

# PAR-C M15: DSN for the least-privileged `xtrusio_reconciler` role that carries
# the `app.bypass_priv_escalation` GUC (the 0013 trigger only honours the bypass
# when current_user = 'xtrusio_reconciler'). OPTIONAL: leave unset in local dev
# and the reconciler falls back to the request engine (logs a warning).
# Provision the role first (migration 0013 creates it NOLOGIN — no secret in
# source), then enable login + set a password out of band:
#   ALTER ROLE xtrusio_reconciler LOGIN PASSWORD '<strong-password>';
# then point this at it (same host/db, the reconciler user):
# RECONCILE_DATABASE_URL=postgresql+asyncpg://xtrusio_reconciler:<PW>@db.<PROJECT_REF>.supabase.co:5432/postgres

# === Supabase API (managed) ===
# Dashboard → Project Settings → API
SUPABASE_URL=https://<PROJECT_REF>.supabase.co
SUPABASE_ANON_KEY=
# service_role bypasses RLS — used by the bootstrap CLI (admin user creation).
# NEVER expose this to the browser or commit it.
SUPABASE_SERVICE_ROLE_KEY=
# Dashboard → Project Settings → API → JWT Settings → JWKS URL.
# Typically https://<PROJECT_REF>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWKS_URL=https://<PROJECT_REF>.supabase.co/auth/v1/.well-known/jwks.json

# === API server bind (uvicorn) ===
API_HOST=127.0.0.1
API_PORT=8000

# === Environment role (required) ===
# "dev" / "prod" / "test" — gates the prod-only pooler-hostname assertion
# and stricter logging behavior at startup.
XTRUSIO_ENV=dev

# === Auth / external-call tuning (seconds) ===
# JWKS doc in-process cache TTL, and the timeouts for the JWKS fetch and the
# Supabase admin call. No tuning constant is hardcoded in Python.
JWKS_TTL_SEC=300
JWKS_FETCH_TIMEOUT_SEC=5
# PAR-B H7: how long the verifier may serve a stale JWKS doc when the
# upstream fetch fails after the cache expires. 0 disables stale-grace.
JWKS_STALE_GRACE_SEC=600
SUPABASE_TIMEOUT_SEC=10

# === Database connection tuning ===
# PAR-B C3: server-side timeouts pushed via asyncpg ``connect_args``.
# Statement timeout in milliseconds (5000 = 5 seconds).
DB_STATEMENT_TIMEOUT_MS=5000
# idle_in_transaction_session_timeout in ms (10000 = 10 seconds).
DB_IDLE_IN_TX_TIMEOUT_MS=10000
# App-side pool config (ignored when DATABASE_URL points at a Supavisor
# pooler — that branch uses NullPool because Supavisor manages pooling).
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE_SEC=1800
DB_POOL_TIMEOUT_SEC=10

# === Request body limits ===
# PAR-B L16: hard cap on request body bytes before Pydantic deserializes.
# 1048576 = 1 MiB. Adjust if a future endpoint legitimately needs more.
MAX_REQUEST_BODY_BYTES=1048576

# === Pagination ===
# PAR-D M5: secret key used to HMAC-sign opaque pagination cursors so clients
# cannot forge/tamper with them. REQUIRED — no default; a known/shipped key lets
# anyone forge a cursor. Generate a fresh random value per environment and NEVER
# reuse the example below:
#   generate: python -c "import secrets; print(secrets.token_hex(32))"
# In prod the app refuses to boot on the dev placeholder or a key < 32 chars.
CURSOR_HMAC_KEY=

# Shared secret the Supabase Database Webhook on auth.audit_log_entries sends in
# the X-Webhook-Secret header to POST /api/internal/auth-events (GoTrue
# login/logout → activity feed `auth` category). REQUIRED — no default; it's the
# only gate on that unauthenticated endpoint. In prod the app refuses to boot on
# the dev placeholder or a secret < 32 chars.
#
# OPERATOR SETUP (do all four — a wrong URL/event/secret makes auth events
# silently never appear in the feed, with no error surfaced):
#   1. Generate:  python -c "import secrets; print(secrets.token_hex(32))"
#   2. Set this var to that value (and restart the API).
#   3. Supabase Dashboard → Database → Webhooks → Create a new hook:
#        - Table:   auth.audit_log_entries     - Events: Insert
#        - Type:    HTTP Request                - Method: POST
#        - URL:     <API_BASE_URL>/api/internal/auth-events
#        - HTTP Header:  X-Webhook-Secret = <the same value from step 1>
#   4. Smoke-test the wiring (expect {"status":"ok"} from a real API):
#        curl -sS -X POST <API_BASE_URL>/api/internal/auth-events \
#          -H "X-Webhook-Secret: <value>" -H "Content-Type: application/json" \
#          -d '{"type":"INSERT","table":"audit_log_entries",
#               "record":{"payload":{"action":"login"}}}'
AUTH_WEBHOOK_SECRET=

# PAR-D M16: TTL (seconds) for the Valkey effective-permission cache behind
# GET /me. Authz checks are never cached; this only bounds /me display staleness.
PERM_CACHE_TTL_SEC=30

# PAR-D H5: poll interval (seconds) for the invite-email outbox worker, which
# sends invite emails out of band of the request transaction.
OUTBOX_POLL_SEC=5

# === Rate-limit hardening (RL-1 / RL-2 / RL-3) — all OPTIONAL ===
# RL-2: per-EMAIL throttle on /api/signup + /api/signup/resend (counts requests
# per normalized target email, backed by Valkey). Defends against email-bombing
# a known victim by rotating source IPs to dodge the per-IP limit. Pure
# request-count throttle — never branches on account state — so it can't become
# an enumeration oracle. Defaults: 5 requests per 3600s window.
SIGNUP_EMAIL_MAX_PER_WINDOW=5
SIGNUP_EMAIL_WINDOW_SEC=3600

# RL-1: authenticated catch-all ceiling — a slowapi limit string applied
# USER-keyed to every authenticated route with no explicit per-route limit
# (health probes are exempt). Generous so a normal multi-query dashboard load
# never trips it; only a single user/token hammering the API hits 429.
AUTHED_CATCHALL_RATE=120/minute

# RL-3: trusted reverse-proxy hop count for client-IP derivation from
# X-Forwarded-For. 0 (default) = trust ONLY the socket peer and IGNORE XFF
# (correct for dev and any directly-exposed deployment). Behind N trusted
# proxies/CDN hops, set this to N — the limiter then reads the (N+1)-th XFF
# entry FROM THE RIGHT (what the outermost trusted proxy saw), never a
# forgeable leftmost client value. PROD: also pin uvicorn
# `--forwarded-allow-ips=<proxy egress IP(s)>` so a direct attacker can't
# inject a forged XFF the app would honour.
RATE_LIMIT_TRUSTED_PROXY_HOPS=0

# === Valkey (local docker-compose; `make valkey-up`) ===
# docker-compose.yml publishes the Valkey container's 6379 on the host loopback
# at 127.0.0.1:63792 (non-default port to avoid clashing with a system Redis on
# 6379). The API/worker run on the host and connect here. Works on any Docker
# engine (Docker Desktop, plain dockerd). Use 127.0.0.1 (not `localhost`) so it
# resolves to IPv4 and never to the ::1 the published port isn't bound to.
VALKEY_URL=redis://127.0.0.1:63792/0

# === Frontend ===
# Vite dev server port (consumed by vite.config.ts).
WEB_DEV_PORT=5173
# Browser URL of the SPA — used in CLI output (bootstrap sign-in hint).
WEB_APP_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8000
VITE_SUPABASE_URL=https://<PROJECT_REF>.supabase.co
# Anon key only — never put service_role in a frontend bundle.
VITE_SUPABASE_ANON_KEY=

# === CORS ===
# Comma-separated browser origins allowed to call the API (the SPA dev server).
CORS_ALLOW_ORIGINS=http://localhost:5173

# === Observability (filled in later plans) ===
SENTRY_DSN=
LOG_LEVEL=INFO

# === Startup posture ===
# When true, RBAC reconcile failures at boot are logged-and-ignored (local dev only).
# Production must keep this `false` so a failed reconcile halts boot rather than
# leaving the app running with silently-stale permissions.
STARTUP_RECONCILE_TOLERANT=false
