# Copy this file to .env and fill in values from your managed Supabase
# project (https://supabase.com/dashboard/project/<ref>/settings/api).
# .env is gitignored — never commit it.

# === Process role (required) ===
# Set to "api" for the FastAPI/Uvicorn process, "worker" for arq workers.
# Local dev: `make api` and `make worker` set this automatically.
XTRUSIO_PROCESS_ROLE=api

# === Supabase project (managed, supabase.com) ===
# From Project Settings → API:
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=<anon key>
SUPABASE_SERVICE_ROLE_KEY=<service_role key>
SUPABASE_JWT_SECRET=<jwt secret>

# === Database connection ===
# From Project Settings → Database → Connection string → URI.
# Use the *pooled* connection string for FastAPI (shared connection pool,
# better for short-lived requests). For long-running workers that hold
# connections, use the direct connection string.
# Replace `postgresql://` with `postgresql+asyncpg://` (SQLAlchemy async driver).
DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<password>@<region>.pooler.supabase.com:6543/postgres

# === Redis (for arq workers; optional in dev) ===
# Local: docker compose up -d redis  → redis://localhost:6379/0
# Remote: Upstash / managed Redis URL
REDIS_URL=redis://localhost:6379/0

# === Frontend (Vite) ===
# Anon key only — never put service_role in a frontend bundle.
VITE_API_BASE_URL=http://localhost:8000
VITE_SUPABASE_URL=https://<ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon key>

# === LLM + scraping providers ===
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=
PERPLEXITY_API_KEY=
FIRECRAWL_API_KEY=

# === Observability ===
SENTRY_DSN=
LOG_LEVEL=INFO
