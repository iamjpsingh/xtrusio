# Copy this file to `.env` and fill in the values from your managed Supabase project.
# `.env` is gitignored — never commit it.

# === Process role (required) ===
# Set to "api" for the FastAPI/Uvicorn process, "worker" for Dramatiq/Prefect.
# Local dev: `make api` and `make worker` set this automatically.
XTRUSIO_PROCESS_ROLE=api

# === Database (managed Supabase Postgres) ===
# Get from Supabase Dashboard → Project Settings → Database → Connection string.
# Use the DIRECT connection (port 5432, host `db.<project-ref>.supabase.co`)
# for Alembic migrations and the FastAPI server. The transaction pooler (6543)
# does NOT support PREPARE and breaks asyncpg + Alembic.
# If you must run on the pooler, switch to the SESSION pooler (port 5432,
# host `aws-0-<region>.pooler.supabase.com`) — transaction pooler is unsupported.
DATABASE_URL=postgresql+asyncpg://postgres:<DB_PASSWORD>@db.<PROJECT_REF>.supabase.co:5432/postgres

# === Supabase API (managed) ===
# Dashboard → Project Settings → API
SUPABASE_URL=https://<PROJECT_REF>.supabase.co
SUPABASE_ANON_KEY=
# service_role bypasses RLS — used by the bootstrap CLI (admin user creation).
# NEVER expose this to the browser or commit it.
SUPABASE_SERVICE_ROLE_KEY=
# Dashboard → Project Settings → API → JWT Settings → JWKS URL.
# Typically https://<PROJECT_REF>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWKS_URL=https://<PROJECT_REF>.supabase.co/auth/v1/.well-known/jwks.json

# === API server bind (uvicorn) ===
API_HOST=127.0.0.1
API_PORT=8000

# === Auth / external-call tuning (seconds) ===
# JWKS doc in-process cache TTL, and the timeouts for the JWKS fetch and the
# Supabase admin call. No tuning constant is hardcoded in Python.
JWKS_TTL_SEC=300
JWKS_FETCH_TIMEOUT_SEC=5
SUPABASE_TIMEOUT_SEC=10

# === Valkey (local docker-compose; reached via OrbStack DNS) ===
# OrbStack publishes container DNS to the host as `<container>.orb.local`,
# so no host port mapping is needed and there is zero conflict with other
# local Docker stacks. If you ever switch to Docker Desktop, add a `ports:`
# entry in docker-compose.yml and change this to `redis://localhost:63792/0`.
VALKEY_URL=redis://xtrusio-valkey.orb.local:6379/0

# === Frontend ===
# Vite dev server port (consumed by vite.config.ts).
WEB_DEV_PORT=5173
# Browser URL of the SPA — used in CLI output (bootstrap sign-in hint).
WEB_APP_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:8000
VITE_SUPABASE_URL=https://<PROJECT_REF>.supabase.co
# Anon key only — never put service_role in a frontend bundle.
VITE_SUPABASE_ANON_KEY=

# === CORS ===
# Comma-separated browser origins allowed to call the API (the SPA dev server).
CORS_ALLOW_ORIGINS=http://localhost:5173

# === Observability (filled in later plans) ===
SENTRY_DSN=
LOG_LEVEL=INFO

# === Startup posture ===
# When true, RBAC reconcile failures at boot are logged-and-ignored (local dev only).
# Production must keep this `false` so a failed reconcile halts boot rather than
# leaving the app running with silently-stale permissions.
STARTUP_RECONCILE_TOLERANT=false
