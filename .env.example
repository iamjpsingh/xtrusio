# === Process role (required) ===
# Set to "api" for the FastAPI/Uvicorn process, "worker" for Dramatiq/Prefect.
# Local dev: `make api` and `make worker` set this automatically.
XTRUSIO_PROCESS_ROLE=api

# === Database (Supabase Postgres, managed by `supabase start`) ===
# Default Supabase CLI Postgres port is 54322. Schema/role: `postgres` user.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:54322/postgres

# === Supabase API (managed by `supabase start`) ===
SUPABASE_URL=http://localhost:54321
# Get the anon + service_role keys by running `make supabase-status`.
# These rotate when you reset Supabase locally; copy them into .env (NOT
# .env.example) for local dev. NEVER commit the service_role key.
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# === Valkey (host port 63792 → xtrusio-valkey:6379 on xtrusio-net) ===
VALKEY_URL=redis://localhost:63792/0

# === Frontend ===
VITE_API_BASE_URL=http://localhost:8000
VITE_SUPABASE_URL=http://localhost:54321
# Anon key only — never put service_role in a frontend bundle.
VITE_SUPABASE_ANON_KEY=

# === Observability (filled in later plans) ===
SENTRY_DSN=
LOG_LEVEL=INFO
